# Axona website — environment variables.
# Copy to `.env.local` (gitignored) and fill real values. NEVER commit real keys.

# Canonical site origin — used for metadataBase, OpenGraph url, and canonical URLs.
# Production: axonahq.com (Railway auto-deploys from main). Set per-environment on Railway.
NEXT_PUBLIC_SITE_URL=https://axonahq.com

# Resend API key — create at https://resend.com (Nicolas). If unset, the request-access form
# degrades gracefully: it validates, logs the lead server-side, and shows the success message —
# it never 500s. So the site is safe to deploy before this is set.
RESEND_API_KEY=

# Where founder notifications are delivered.
REQUEST_ACCESS_TO=nibaranowski@gmail.com

# The "from" sender. Resend requires a verified domain. Until axonahq.com DNS is verified, use the
# Resend sandbox sender so sends work pre-DNS; swap to access@axonahq.com after verification.
# (Tracked in docs/pre-launch-swap.md.)
REQUEST_ACCESS_FROM=onboarding@resend.dev
