# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# autonomous build loop (SETUP.5) — ignore generated logs, keep the dir via .gitkeep
logs/build-loop/*.log
logs/build-loop/*.jsonl
logs/build-loop/.lock
!logs/build-loop/.gitkeep

# scaffold scratch
.axona-scaffold/
